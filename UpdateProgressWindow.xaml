<Window x:Class="TileLauncherGUI.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="正在更新..." Height="150" Width="400" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="None">
    <Border BorderBrush="Gray" BorderThickness="1">
        <StackPanel VerticalAlignment="Center" Margin="20">
            <TextBlock Text="正在下载更新，请稍候..." x:Name="txtMessage" Margin="0,0,0,10"/>
            <ProgressBar x:Name="pbDownload" Height="20" Minimum="0" Maximum="100"/>
            <TextBlock x:Name="txtProgress" Text="0%" HorizontalAlignment="Right" Margin="0,5,0,0"/>
        </StackPanel>
    </Border>
</Window>